  "root_causes": [
    {
      "id": "core_unverified_exit",
      "severity": "P0",
      "location": "eidetic/retrieval.py:5067-5128",
      "finding": "When verification finds no entailed source but coverage or abstention-v2 confidence is high, reader text is returned with verified=false instead of being replaced by an abstention."
    },
    {
      "id": "benchmark_parallel_policy",
      "severity": "P0",
      "location": "bench/adapters/eidetic_adapter.py:275-407",
      "finding": "The product benchmark duplicates generation, verification, and abstention policy and can explicitly override abstention or run an unverified dense-reader fallback."
    },
    {
      "id": "public_verify_bypass",
      "severity": "P0",
      "location": "eidetic/engine.py:945-947; eidetic/api.py:73-78,186-203; eidetic/mcp_server.py:271-284,438-451",
      "finding": "Public answer surfaces accept verify=false and can therefore request factual generation without proof."
    },
    {
      "id": "implicit_status",
      "severity": "P0",
      "location": "eidetic/models.py:234-243",
      "finding": "Answer has no explicit VERIFIED-or-ABSTAINED status; callers infer abstention from note text."
    },
    {
      "id": "empty_store_false_verification",
      "severity": "P0",
      "location": "eidetic/retrieval.py:4910-4915",
      "finding": "No-memory output is marked verified=true despite having no proof; it should be an explicit abstention."
    },
    {
      "id": "notebooklm_draft_boundary",
      "severity": "P0",
      "location": "eidetic/integrations/notebooklm.py:1183-1269; eidetic/mcp_server.py:353-435",
      "finding": "NotebookLM outputs are honestly labeled as non-gated today, but public tools return raw Gemini answer text. Governed use requires an UntrustedDraft that passes the same canonical proof service before any answer can ship."
    }
  ],
  "phase_a_narrow_fix_order": [
    "Introduce explicit answer status with a fail-closed public invariant.",
    "Force every failed verification result, including empty-store results, to ABSTAINED with no citations or draft text.",
    "Remove public verify bypasses while retaining clearly internal diagnostic draft/evidence APIs.",
    "Make the benchmark product adapter call canonical product orchestration; delete coverage and dense unverified answer overrides.",
    "Add NotebookLM as an UntrustedDraft reader strategy behind canonical proof; keep raw-draft research output separately labeled.",
    "Replay burned rows mechanically first, then run offline tests and real-provider smoke without consuming fresh holdout windows."
  ]
