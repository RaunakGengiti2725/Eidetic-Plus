# ============================================================================
# Eidetic-Plus configuration. Copy to `.env` and fill in DASHSCOPE_API_KEY.
# Everything here is read at startup by eidetic/config.py.
# ============================================================================

# --- Environment -----------------------------------------------------------
# dev  = local immutable substrate + local vector index + SQLite state.
# prod = Alibaba Cloud OSS-WORM + AnalyticDB-PG + GDB (see docs/architecture.md).
# Only storage/DB swaps between dev and prod. All model calls are identical.
APP_ENV=dev

# --- Qwen / DashScope (REQUIRED for any model call; no mocks, ever) ---------
# Get a key at https://dashscope.console.aliyun.com (or the intl console).
DASHSCOPE_API_KEY=

# Region selects the endpoint + the multimodal embedder.
#   singapore -> dashscope-intl.aliyuncs.com (text-embedding-v4 + tongyi-embedding-vision)
#   beijing   -> dashscope.aliyuncs.com (enables qwen3-vl-embedding FUSION mode, Beijing-only)
DASHSCOPE_REGION=singapore

# --- Model IDs (override here if Qwen renames a model; IDs churn fast) ------
TEXT_EMBED_MODEL=text-embedding-v4
# Multimodal embedder. singapore default below; for beijing use qwen3-vl-embedding.
MULTIMODAL_EMBED_MODEL=tongyi-embedding-vision-plus
EMBED_DIM=1024

SALIENCE_MODEL=qwen-flash
EXTRACT_MODEL=qwen-plus
VERIFY_MODEL=qwen-plus
RERANK_MODEL=qwen3-rerank
GEN_MODEL=qwen3-max
CONSOLIDATE_MODEL=qwen-plus
DESCRIBE_MODEL=qwen-vl-plus

# Ingestion models
OCR_MODEL=qwen-vl-ocr
ASR_MODEL=qwen3-asr-flash
DOC_MODEL=qwen-long       # Files API file-extract reader; account must have access (see doctor)
VIDEO_MODEL=qwen-vl-plus

# --- Local storage (dev) ---------------------------------------------------
DATA_DIR=./data
VECTOR_BACKEND=auto          # auto | hnswlib | numpy
STRUCT_DIM=64                # structure-code (cognitive-coordinate) vector dim

# --- Retrieval tuning ------------------------------------------------------
ANN_TOPK=100                 # k1: ANN candidate pool
FINAL_TOPK=10                # k2: after rerank
RRF_K=60                     # reciprocal-rank-fusion constant
READER_COT=0                 # Chain-of-Note JSON reader scaffold, shared by all adapters
READER_ROUTER=1              # product answer model router, fixed-reader harness pins its own model
CONFLICT_RESOLVER=0          # deterministic current-value resolver
CONTEXT_COMPRESS=0           # enable extractive context compression when COMPRESSION_RATIO < 1.0
EXTRACT_LIGHT=0              # use qwen-flash for graph extraction instead of qwen-plus
TEMPORAL_RERANK=0            # timestamp-order temporal/latest context before the fixed reader
HIPPO2_SEEDING=0             # add query-to-triple endpoints as scoped PPR seeds
PERSISTENT_BM25=1            # reuse tokenized lexical index instead of rebuilding per query
SEMANTIC_CACHE=1             # scoped answer cache for exact and near-duplicate queries
SEMANTIC_CACHE_ADAPTIVE=1    # stricter for short/time queries, looser for long specific queries

# --- Always-on optimization (three-tier menu; ALL default OFF / current behavior) ---
# The shipped baseline is unchanged; each optimizer is an independent A/B flag. The offline
# tuner (bench.sweep) and calibrator (bench.calibrate) read the private DEV split ONLY;
# reported numbers come from --split test. See docs/optimization.md.
#
# Layer 2 (per-query hot path):
ADAPTIVE_K=0                 # 2a largest-gap cut of the candidate list (token savings)
ADAPTIVE_K_MIN=3            #    floor for the adaptive-k cut
ADAPTIVE_EF=0                # 2a raise HNSW efSearch only for hard (multi-hop/long) queries
HNSW_EF_SEARCH_HARD=512    #    the widened beam for hard queries
CONFORMAL_DEPTH=0            # 2b split-conformal retrieval depth (keep sim >= 1 - qhat)
CONFORMAL_ALPHA=0.1        #    target miscoverage
CONFORMAL_QHAT=-1.0        #    calibrated on the DEV split (bench.calibrate --method conformal); <0 = off
RERANK_SKIP_MARGIN=0.0      # 2c skip the cross-encoder when the first-stage margin >= this (0 = never)
MMR_ENABLED=0               # 2c MMR diversity post-pass
MMR_LAMBDA=0.5             #    diversity weight in [0.3,0.7]
FUSION_METHOD=rrf           # 2d rrf | zscore | minmax | dbsf | borda
PARALLEL_CHANNELS=0         # 2e run dense/BM25/recency channels concurrently
#
# Layer 3 (background / continuous):
VECTOR_QUANT=none           # 3c none | sq8 (int8, 4x) | rabitq (1-bit, 32x)
QUANT_REFINE=1             #    keep the exact float32 refine pass (recall recovery)
QUANT_REFINE_TOPN=100      #    code-shortlist size before exact refine
ROCCHIO=0                   # 3b pseudo-relevance-feedback query expansion (confidence-gated)
FUSION_LEARNER=0            # 3a use dev-feedback-learned content-channel fusion weights
FUSION_LEARNER_METHOD=eg   #    eg (exponentiated gradient) | ftrl
FEEDBACK=0                  #    emit dev-only (features, reward) tuples from the product ask() path

# --- Self-healing + society-of-memory (Revolutionary Architectures; ALL default OFF) ---
# Deterministic cores are unit-tested offline; the LLM orchestration is gated + fail-loud and
# unrun under quota. See docs/self-healing.md (live vs scaffolding vs skipped + the runbook).
GUARD_ENABLED=0              # EvolveMem auto-revert guard (promote a config only on a significant dev win)
GUARD_MIN_DELTA_PP=1.0      #   minimum dev accuracy-point gain to promote
GUARD_ALPHA=0.05           #   paired-McNemar significance level
MEMORY_MANAGER=0            # heuristic ADD/UPDATE/DELETE-tombstone/NOOP write-time router (Memory-R1 approx)
MEMORY_MANAGER_DUP_COSINE=0.97  #   NOOP duplicate threshold
DREAM_REPAIR=0              # MemMA self-repair sweep in the dreaming engine (probe->diagnose->SKIP/MERGE/INSERT)
DREAM_REPAIR_TOPK=16       #   how many highest-anomaly memories to probe per sweep
ANOMALY_THRESHOLD=0.35     # per-triple confidence below which an observed edge is a repair target
MEMORY_TYPING=0             # MIRIX role typing (core/episodic/semantic/procedural/resource/knowledge_vault)
ACTIVE_RETRIEVAL=0          # MIRIX Active Retrieval: anticipate a topic before answering (LLM)
MARKOV_PREFETCH=0           # prospective memory: learn P(next query|current) for predictive prefetch
COVE=0                      # Chain-of-Verification: factored, independently-answered fact-checks (LLM)
COVE_QUESTIONS=3            #   verification questions planned per draft when COVE=1
DEBATE=0                    # bounded 2-3 agent cross-check debate on detected conflicts only (LLM)
SPAN_NLI=0                  # verify EACH sentence/claim against sources (one ungrounded claim -> abstain) (LLM)
SPAN_NLI_MIN_CHARS=12      #   skip claim fragments shorter than this

# --- Benchmark-dominance capture-fidelity (ALL default OFF; defaults are byte-identical) ---------
# Stop silently losing bytes / retrievability. Each multiplies write-time work, hence gated.
EXTRACT_CHUNKING=0          # split sessions >6000 chars into overlapping windows for extraction (LLM x2-3)
EXTRACT_CHUNK_CHARS=4000   #   window size
EXTRACT_CHUNK_OVERLAP=400  #   window overlap (capture continuity across the cut)
PREF_SENTENCE_SCAN=0        # one profile line per preference sentence, not just the first (token-free)

# --- Benchmark harness knobs (read by bench/*, not the engine; defaults reproduce prior runs) ----
# READER_BLOCK_CHARS=3000   per-block char cap fed to the shared reader (raise to 8000)
# READER_MODE=default       'photographic'/'extractive' -> verbatim-quoting reader, all systems
# INGEST_GRANULARITY=session 'turn' | 'hybrid' (session record + turn-window records)
# INGEST_WINDOW_TURNS=5      turns per hybrid window
# FULL_SLEEP=0              1 -> consolidate_pending + dream replay/infer/multi-resolution gist
# DREAM_AB=0               1 -> one extra dream pass after consolidate (A/B the dreaming layer)

# --- Phase-1 multi-view retrieval channels (Memory Agent Upgrade; ALL default OFF) ---
# Each wires a dormant signal into the fused candidate ranking. Age-independence preserved:
# structure code is cyclic-time only (never absolute age); event channel ranks by the QUERY's
# time constraint, not memory age. Re-prove with engine.prove_age_independence after enabling.
STRUCT_CHANNEL=0            # structure-code channel (entity/role/modality similarity)
RRF_W_STRUCT=0.5
EVENT_RANKING=0            # promote event-calendar interval matches into candidate ranking
RRF_W_EVENT=0.7
GIST_CHANNEL=0             # derived-gist channel: a gist match boosts its raw member memories
RRF_W_GIST=0.4
GRAPH_VOCAB_SEEDING=0      # seed PPR from query tokens matched against in-scope store vocabulary
COACTIVATION_CHANNEL=0     # Phase 2: pull in memories co-confirmed with top dense hits (CO_ACTIVATED)
RRF_W_COACT=0.5
MEMORY_TYPING=0            # Phase 4: classify type on ingest + soft type-priority retrieval prior
TYPE_PRIOR_WEIGHT=0.15     # max type-match bonus as a fraction of the top fused score
DREAM_REPAIR_APPLY=0       # Phase 5: allow guarded repair APPLY (additive ingest; never deletes raw)

# --- Connected Brain Loop: observation-only spine (ALL default OFF; baseline byte-identical) --
# RECALL_TRACE: retriever records WHY it found/missed (channels, weights, fused scores, stage
# latency, dropped candidates) into retriever.last_trace. Pure side channel -- when on, the
# returned candidate list is identical to the off path. Powers prove(with_paths=True) recall paths.
RECALL_TRACE=0
# BRAIN_EVENTS: engine emits a typed improvement stream (ingest/recall/verify/abstain/...) into
# engine.brain_log. In-memory + NON-LEARNING; if ever persisted or fed to a learner it MUST honor
# the FeedbackBuffer integrity wall (is_benchmark_namespace / is_dev).
BRAIN_EVENTS=0

# --- Best Memory Agent phases (ALL default OFF; baseline byte-identical; not promoted) ---------
# Phase 2 calibrated abstention: confidence = w_entail*entailment + w_coverage*coverage +
# w_agreement*channel_agreement + w_proof*proof_completeness; abstain if < tau (dev-calibrated).
ABSTENTION_V2=0
ABSTENTION_V2_TAU=0.5
ABSTENTION_W_ENTAIL=0.4
ABSTENTION_W_COVERAGE=0.2
ABSTENTION_W_AGREEMENT=0.2
ABSTENTION_W_PROOF=0.2
# Phase 3 affect-modulated salience: s = sigmoid(wA*arousal + wL*importance + wP*surprise +
# wU*emphasis + wR*verified_helpful - midpoint). NO age term. Bounded retrieval boost + FSRS S0 +
# replay only -- never deletion.
AFFECT_SALIENCE=0
AFFECT_W_AROUSAL=1.0
AFFECT_W_IMPORTANCE=1.0
AFFECT_W_SURPRISE=1.0
AFFECT_W_EMPHASIS=1.0
AFFECT_W_HELPFUL=0.0       # Phase 4 verified-helpful weight (0 until tuned on dev)
LAMBDA_SALIENCE=0.1        # bounded retrieval boost strength
SALIENCE_GAMMA=0.5         # FSRS initial-stability coupling (replay/scheduling only, not ranking)
SALIENCE_ALPHA=1.0         # replay-priority exponent
VERIFIED_HELPFUL_CAP=5     # Phase 4: saturation cap for the verified-helpful usage signal
EVENT_CHAIN_CONTEXT=0      # Phase 5: chronological event chain in context for order/temporal queries
SCRATCHPAD=0               # Phase 6: working scratchpad of high-salience verified facts (links raw)
SCRATCHPAD_TOPK=5
SCRATCHPAD_MIN_SALIENCE=0.6

# --- Fastest-best-agent: safety + governance (F0/F1 not flag-gated except the governor toggle) -
DASHSCOPE_GOVERN=1            # F1 rate governor on every model call (token bucket + semaphore + 429 backoff)
DASHSCOPE_RPM=60             # requests/min budget (conservative; raise for a higher tier)
DASHSCOPE_MAX_CONCURRENCY=4  # concurrent in-flight model calls
DASHSCOPE_MAX_RETRIES=5
DASHSCOPE_BACKOFF_BASE=0.5
DASHSCOPE_BACKOFF_MAX=30.0
EMBED_CACHE=1                # S4 persistent embedding cache keyed by (model, dim, sha256(text))

# --- Fastest-best-agent: speed knobs (ALL default OFF; semantics preserved, measure before promote)
BATCH_NLI=0                  # S1 judge all candidate sources in ONE request instead of N
DEFER_REEMBED=0             # S1 push confirmed-citation re-embed to the idle/sleep drain
FAST_VERIFY=0              # S1 short-circuit verification after the citation cap
VERIFY_CITATION_CAP=3
INDEX_SAVE_DEBOUNCE=1       # S2 save every ingest (baseline); higher amortizes (rebuild recovers)
SPECULATIVE_CASCADE=0      # S5 cheap reader tier first, escalate to strong only on a grounding miss
DIFFICULTY_ADAPTIVE_DEPTH=0 # S5 scale returned candidate count with query difficulty

# --- Consolidation / forgetting -------------------------------------------
CONSOLIDATION_INTERVAL_SEC=3600   # local scheduler period for the sleep loop

# --- Prod-only (Alibaba Cloud); ignored when APP_ENV=dev -------------------
OSS_BUCKET=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_WORM_RETENTION_DAYS=3650
ADBPG_DSN=
GDB_ENDPOINT=
